# Local development — copy this to .env and fill in values.
# .env is gitignored and must never be committed.
#
# In production, all values are fetched from Google Secret Manager.
# For local dev, either:
#   (a) use `gcloud auth application-default login` and leave these blank
#       (get_secret() will call Secret Manager directly), or
#   (b) fill in real values here and temporarily patch get_secret() to read
#       from this file via python-dotenv.

MILON_EMAIL=your-milon-email@example.com
MILON_PASSWORD=your-milon-password
MILON_API_KEY=your-milon-api-key
MILON_USER_ID=your-milon-user-id
MILON_STUDIO_ID=your-milon-studio-id
MILON_TRAINING_ID=your-milon-training-id
NEON_DATABASE_URL=postgresql://user:password@host/dbname